# Local Supabase (required)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_KEY=

# Optional — enables prod toggle in the sidebar
VITE_SUPABASE_PROD_URL=
VITE_SUPABASE_PROD_KEY=

# Coach panel (Video Overlay page) — admin-only OpenAI key.
# This key is bundled into the dev build. The dashboard is never deployed;
# keep it that way. Leave blank if you are not iterating on form coaching.
VITE_OPENAI_KEY=
